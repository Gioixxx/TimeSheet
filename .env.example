# Copy to `.env` in the project root for local dev (Prisma CLI + Next.js load `.env`).
# Paths for SQLite are relative to the `prisma/` folder where `schema.prisma` lives.

DATABASE_URL="file:./timesheet.db"

# Optional — natural-language time entry parsing (Gemini)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
