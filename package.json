{
  "name": "timesheet",
  "version": "0.1.0",
  "private": true,
  "description": "Timesheet desktop (Next.js + Electron)",
  "author": "",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "electron": "electron .",
    "prepare:standalone": "node scripts/prepare-standalone.mjs",
    "dist:win": "next build && npm run prepare:standalone && electron-builder --win portable --x64"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^3.9.0",
    "@prisma/client": "^6.7.0",
    "lucide-react": "^0.469.0",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.54.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^36.3.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "prisma": "^6.7.0",
    "typescript": "^5"
  },
  "build": {
    "appId": "com.timesheet.app",
    "productName": "Timesheet",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "npmRebuild": false,
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "standalone"
      },
      {
        "from": "prisma",
        "to": "prisma"
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
